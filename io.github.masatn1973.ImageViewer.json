{
    "app-id": "io.github.masatn1973.ImageViewer",
    "runtime": "org.gnome.Platform",
    "runtime-version": "50",
    "sdk": "org.gnome.Sdk",
    "command": "imageviewer",
    "separate-locales": false,
    "finish-args": [
        "--share=ipc",
        "--device=dri",
        "--socket=fallback-x11",
        "--socket=wayland"
    ],
    "cleanup": [
        "/include",
        "/lib/pkgconfig",
        "/share/doc",
        "/share/gtk-doc",
        "/share/man",
        "/share/pkgconfig",
        "*.la",
        "*.a"
    ],
    "modules": [
        {
            "name": "imageviewer",
            "buildsystem": "meson",
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/masatn1973/imageviewer.git",
                    "commit": "d2ec7717384ca34ee62a2e973a7f2c8d838d02c9"
                }
            ]
        }
    ]
}
