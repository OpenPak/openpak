{
  "app-id": "io.github.ljyh223.Linn",
  "runtime": "org.gnome.Platform",
  "runtime-version": "50",
  "sdk": "org.gnome.Sdk",
  "sdk-extensions": [
    "org.freedesktop.Sdk.Extension.rust-stable"
  ],
  "command": "linn",
  "finish-args": [
    "--share=network",
    "--share=ipc",
    "--socket=fallback-x11",
    "--socket=wayland",
    "--socket=pulseaudio",
    "--device=dri",
    "--filesystem=xdg-music:ro"
  ],
  "build-options": {
    "append-path": "/usr/lib/sdk/rust-stable/bin",
    "build-args": [
      "--share=network"
    ],
    "env": {
      "CARGO_HOME": "/run/build/linn/cargo"
    }
  },
  "cleanup": [
    "/include",
    "/lib/pkgconfig",
    "/man",
    "/share/man",
    "/share/gtk-doc",
    "*.la",
    "*.a"
  ],
  "modules": [
    {
      "name": "linn",
      "buildsystem": "simple",
      "build-commands": [
        "cargo build --release --manifest-path Cargo.toml",
        "install -Dm755 target/release/linn /app/bin/linn",
        "install -Dm644 data/io.github.ljyh223.Linn.gschema.xml /app/share/glib-2.0/schemas/io.github.ljyh223.Linn.gschema.xml",
        "install -Dm644 data/io.github.ljyh223.Linn.desktop /app/share/applications/io.github.ljyh223.Linn.desktop",
        "install -Dm644 data/io.github.ljyh223.Linn.metainfo.xml /app/share/metainfo/io.github.ljyh223.Linn.metainfo.xml",
        "install -Dm644 data/io.github.ljyh223.Linn.svg /app/share/icons/hicolor/scalable/apps/io.github.ljyh223.Linn.svg",
        "glib-compile-schemas /app/share/glib-2.0/schemas"
      ],
      "sources": [
        {
          "type": "git",
          "url": "https://github.com/ljyh223/linn.git",
          "tag": "v1.1.0",
          "commit": "ce4219082c11e7c3eb9827e5ff6904a14ee9e04e"
        },
        {
          "type": "file",
          "path": "generated-sources.json"
        }
      ]
    }
  ]
}
